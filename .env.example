# Copy this to .env and fill in your values
PORT=3000

# Generate a strong random string for admin access
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=replace_with_a_strong_random_string

# Get this from Whop dashboard → Settings → Webhooks
WHOP_WEBHOOK_SECRET=replace_with_whop_webhook_secret
